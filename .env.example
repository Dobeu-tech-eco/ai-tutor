# --- AI coach (Anthropic) ---
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# Optional override; defaults to a current Claude model in code
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Booking email (Resend) ---
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Verified sender + destination for booking notifications
BOOKING_FROM_EMAIL=Dobeu Coach Connect <bookings@dobeu.net>
BOOKING_TO_EMAIL=hello@dobeu.net

# --- Rate limiting (Upstash Redis / Vercel KV integration) ---
KV_REST_API_URL=
KV_REST_API_TOKEN=
